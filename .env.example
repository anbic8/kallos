# JudoApp -- Umgebungsvariablen
# Datei kopieren: cp .env.example .env  und Werte eintragen

# --- Pflichtfelder (kein Default -- App startet nicht ohne diese!) ---

# Datenbankpasswort
DB_PASSWORD=hier-sicheres-passwort-eintragen

# JWT-Signaturschluessel -- mindestens 32 zufaellige Zeichen
# Erzeugen z.B. mit: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=hier-langen-zufallsstring-eintragen

# Initiales Admin-Passwort (wird beim ersten Start in die DB geschrieben)
ADMIN_PASSWORD=hier-admin-passwort-eintragen

# --- Optionale Felder (Defaults in Klammern) ---

# Datenbankverbindung
DB_USER=judoapp
DB_NAME=judoapp

# Admin-Account
ADMIN_EMAIL=admin@judoapp.de

# Name des eigenen Vereins (wird beim ersten Start automatisch angelegt)
HEIMVEREIN_NAME=Mein Judoverein

# Erlaubte CORS-Origins -- kommagetrennt, kein Leerzeichen zwischen Eintraegen
# Muss die URL(s) enthalten, ueber die das Frontend erreichbar ist
ALLOWED_ORIGINS=http://localhost:8002
